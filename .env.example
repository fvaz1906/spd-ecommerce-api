NODE_ENV=production
PORT=3000
API_PREFIX=api
API_VERSION=v1
APP_NAME=SPD Ecommerce API
APP_URL=https://api.seudominio.com.br
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
CORS_ORIGINS=https://app.seudominio.com.br
CORS_CREDENTIALS=true
DOCS_ENABLED=false
ALLOW_PUBLIC_API_DOCS=false
TRUST_PROXY=true
GLOBAL_RATE_LIMIT_TTL_MS=60000
GLOBAL_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_TTL_MS=60000
AUTH_RATE_LIMIT_MAX=5
HTTP_BODY_LIMIT=1mb
MAIL_HOST=smtp.seuprovedor.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=seu-usuario
MAIL_PASS=sua-senha
MAIL_FROM=SPD Ecommerce <no-reply@seudominio.com.br>
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_BUCKET_NAME=your-bucket-name
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://your-public-bucket-url.r2.dev
